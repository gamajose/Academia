PORT=3004
NODE_ENV=production
DATABASE_URL=postgresql://USUARIO:SENHA_FORTE@127.0.0.1:5432/academia
AUTH_SECRET=GERE_UM_SEGREDO_ALEATORIO_COM_PELO_MENOS_32_CARACTERES
AUTH_TOKEN_TTL_MS=28800000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8084,http://localhost:8084,http://192.168.3.200:8084
APP_PUBLIC_URL=http://192.168.3.200:8084
EMAIL_FROM=contato@academialobo.com.br
# Webhook JSON opcional: {to,from,subject,text,html}. Sem ele, a mensagem fica pendente para configurar.
EMAIL_WEBHOOK_URL=
# Mercado Pago: cria o Pix e recebe a confirmação automática no webhook.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_API_URL=https://api.mercadopago.com
# PayPal: sandbox aceita conta PayPal e cartão pelo checkout hospedado.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
DB_POOL_MAX=20
REQUEST_BODY_LIMIT_BYTES=1048576
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
GOOGLE_WEB_CLIENT_ID=
GOOGLE_MOBILE_CLIENT_ID=

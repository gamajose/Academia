{
  "name": "academia-desktop",
  "version": "0.2.0",
  "private": true,
  "description": "Software desktop para Academia Platform",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "br.com.academia.platform",
    "productName": "Academia Platform",
    "directories": { "output": "dist" },
    "files": ["main.js", "../web/**/*"]
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^24.13.3"
  }
}
